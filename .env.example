# --- Legacy bot/sqlite ---
TG_TOKEN=
DB_PATH=./db/olymp.db
API_KEY=
ADMIN_PASSWORD=

# --- Docker images ---
API_IMAGE=recod0/dmk-logistic-api:latest
WEB_IMAGE=recod0/dmk-logistic-web:latest

# --- Postgres / new mobile stack ---
POSTGRES_DB=dmk_logistic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@db:5432/dmk_logistic
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/dmk_logistic

# --- JWT auth ---
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Optional bootstrap user for local env ---
BOOTSTRAP_DEMO_USER=1
DEMO_LOGIN=driver
DEMO_PASSWORD=driver123
DEMO_ROLE=driver

# --- Web/PWA ---
VITE_API_BASE_URL=/api

